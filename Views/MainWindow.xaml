<Window x:Class="MeuIPTVPro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Meu IPTV Pro"
        Height="820"
        Width="1360"
        MinHeight="720"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0B0D12"/>
        <!-- Forçar fundo de controles (ComboBox dropdown e seleção) para escuro -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1F2531"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1F2531"/>
        <SolidColorBrush x:Key="Panel" Color="#151923"/>
        <SolidColorBrush x:Key="Panel2" Color="#1F2531"/>
        <SolidColorBrush x:Key="Accent" Color="#E50914"/>
        <SolidColorBrush x:Key="TextMain" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A8B0C0"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252B37"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F2531"/>
            <Setter Property="BorderBrush" Value="#333B4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Estilo específico para o CategoryBox (escuro, texto branco) -->
        <Style x:Key="CategoryComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1F2531"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333B4B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A313D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F2531"/>
            <Setter Property="BorderBrush" Value="#333B4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource CategoryComboBoxItemStyle}"/>

            <!-- Simple ControlTemplate that preserves the SelectionBoxItem and shows a dark arrow area -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <DockPanel LastChildFill="True">
                                    <ContentPresenter x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      Margin="6,0,0,0"
                                                      RecognizesAccessKey="True"
                                                      />

                                    <ToggleButton x:Name="ToggleButton"
                                                  DockPanel.Dock="Right"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Width="36"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center">
                                        <Path Fill="White" Data="M 0 0 L 8 0 L 4 5 Z" Width="10" Height="6"/>
                                    </ToggleButton>
                                </DockPanel>
                            </Border>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#1F2531" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="4">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Popup" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MenuColumn" Width="220" MinWidth="220"/>
            <ColumnDefinition x:Name="ListColumn" Width="410" MinWidth="360"/>
            <ColumnDefinition Width="*" MinWidth="520"/>
        </Grid.ColumnDefinitions>

        <!-- MENU LATERAL -->
        <Border x:Name="SideMenu"
                Grid.Column="0"
                Background="#11151F"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Meu IPTV Pro"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,8,0,6"/>

                    <TextBlock Text="Streaming Center"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               Margin="0,0,0,28"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Content=" TV Ao Vivo"
                            Height="48"
                            Margin="0,0,0,10"
                            Background="{StaticResource Accent}"
                            HorizontalContentAlignment="Left"/>

                    <Button Content=" Filmes"
                            Height="48"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"/>

                    <Button Content=" Séries"
                            Height="48"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"/>

                    <Button Content="⭐ Favoritos"
                            Height="48"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"/>

                    <Button Content="⚙ Configurações"
                            Height="48"
                            Margin="0,0,0,10"
                            HorizontalContentAlignment="Left"/>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Use apenas serviços autorizados"
                           Foreground="#6F7788"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- PAINEL DE CANAIS -->
        <Border x:Name="ChannelPanel"
                Grid.Column="1"
                Background="#0F131C"
                Padding="18">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho responsivo -->
                <Grid Grid.Row="0" Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Canais"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>

                    <Border Grid.Column="1"
                            Background="#1F2531"
                            CornerRadius="12"
                            Padding="10,5"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">

                        <TextBlock x:Name="ChannelCountText"
                                   Text="0 canais"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap"/>
                    </Border>
                </Grid>

                <!-- Busca -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <TextBox x:Name="SearchBox"
                             Height="44"
                             TextChanged="SearchBox_TextChanged"/>

                    <TextBlock Text="Pesquisar canais..."
                               Foreground="#6F7788"
                               FontSize="14"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Categorias -->
                <ComboBox x:Name="CategoryBox"
                          Grid.Row="2"
                          Height="42"
                          Margin="0,0,0,14"
                          SelectionChanged="CategoryBox_SelectionChanged"
                          Style="{StaticResource CategoryComboBoxStyle}"/>

                <!-- Lista -->
                <ListBox x:Name="ChannelList"
                         Grid.Row="3"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="ChannelList_SelectionChanged"
                         MouseDoubleClick="ChannelList_MouseDoubleClick"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1C2230"
                                    CornerRadius="14"
                                    Padding="12"
                                    MinHeight="72">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="42"
                                            Height="42"
                                            CornerRadius="12"
                                            Background="#07090D"
                                            VerticalAlignment="Center">

                                        <Grid>
                                            <Image Source="{Binding LogoUrl}"
                                                   Stretch="Uniform"
                                                   Margin="6"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="12,0,8,0">

                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="#9AA3B5"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="☆"
                                               Foreground="#F5C542"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ÁREA DO PLAYER -->
        <Grid x:Name="PlayerArea"
              Grid.Column="2"
              Background="Black"
              MouseLeftButtonDown="PlayerArea_MouseLeftButtonDown">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="ControlsRow" Height="82"/>
            </Grid.RowDefinitions>

            <Border x:Name="PlayerFrame"
                    Grid.Row="0"
                    Background="Black"
                    Margin="18,18,18,0"
                    CornerRadius="18"
                    ClipToBounds="True">

                <Grid Background="Black">
                                    <!-- ensure no padding/margin inside player frame -->
                    <vlc:VideoView x:Name="VideoPlayer"
                                   Background="Black"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Margin="0"
                                   Padding="0"/>

                    <Border x:Name="OverlayPanel"
                            Background="#CC000000">

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                            <TextBlock x:Name="PlayerPlaceholder"
                                       Text="Selecione um canal"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Duplo clique no canal para reproduzir"
                                       Margin="0,12,0,0"
                                       Foreground="#A8B0C0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- CONTROLES DO PLAYER -->
            <Border x:Name="PlayerControls"
                    Grid.Row="1"
                    Background="#171B25"
                    CornerRadius="16"
                    Margin="18,14,18,18"
                    Padding="14">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="▶ Reproduzir"
                            Width="130"
                            Margin="0,0,10,0"
                            Background="{StaticResource Accent}"
                            Click="Play_Click"/>

                    <Button Grid.Column="1"
                            Content="⏸ Pausar"
                            Width="100"
                            Margin="0,0,14,0"
                            Click="Pause_Click"/>

                    <TextBlock x:Name="NowPlayingText"
                               Grid.Column="2"
                               Text="Nenhum canal selecionado"
                               Foreground="White"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,14,0"/>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">

                        <TextBlock Text="Volume"
                                   Foreground="#A8B0C0"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <Slider x:Name="VolumeSlider"
                                Width="120"
                                Minimum="0"
                                Maximum="100"
                                Value="80"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>

                    <Button Grid.Column="4"
                            Content="⛶ Tela cheia"
                            Width="130"
                            Background="{StaticResource Accent}"
                            Click="Fullscreen_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>