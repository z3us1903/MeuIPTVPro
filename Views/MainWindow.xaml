<Window x:Class="MeuIPTVPro.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="Meu IPTV Pro"
        Height="820"
        Width="1360"
        MinHeight="720"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0B0D12"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0B0D12"/>
        <SolidColorBrush x:Key="Panel" Color="#151923"/>
        <SolidColorBrush x:Key="Panel2" Color="#1F2531"/>
        <SolidColorBrush x:Key="Accent" Color="#E50914"/>
        <SolidColorBrush x:Key="TextMain" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A8B0C0"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#252B37"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F2531"/>
            <Setter Property="BorderBrush" Value="#333B4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F2531"/>
            <Setter Property="BorderBrush" Value="#333B4B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource Bg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="MenuColumn" Width="220"/>
            <ColumnDefinition x:Name="ListColumn" Width="390"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="SideMenu" Grid.Column="0" Background="#11151F" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Meu IPTV Pro"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,8,0,6"/>
                    <TextBlock Text="Streaming Center"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               Margin="0,0,0,28"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Content="📺  TV Ao Vivo" Height="48" Margin="0,0,0,10" Background="{StaticResource Accent}" HorizontalContentAlignment="Left"/>
                    <Button Content="🎬  Filmes" Height="48" Margin="0,0,0,10" HorizontalContentAlignment="Left"/>
                    <Button Content="📚  Séries" Height="48" Margin="0,0,0,10" HorizontalContentAlignment="Left"/>
                    <Button Content="⭐  Favoritos" Height="48" Margin="0,0,0,10" HorizontalContentAlignment="Left"/>
                    <Button Content="⚙  Configurações" Height="48" Margin="0,0,0,10" HorizontalContentAlignment="Left"/>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Use apenas serviços autorizados"
                           Foreground="#6F7788"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Border x:Name="ChannelPanel" Grid.Column="1" Background="#0F131C" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,8,0,16">
                    <TextBlock Text="Canais"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               DockPanel.Dock="Left"/>
                    <TextBlock x:Name="ChannelCountText"
                               Text="0"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="13"
                               VerticalAlignment="Bottom"
                               Margin="10,0,0,4"/>
                </DockPanel>

                <TextBox x:Name="SearchBox"
                         Grid.Row="1"
                         Height="44"
                         Margin="0,0,0,12"
                         TextChanged="SearchBox_TextChanged"/>

                <ComboBox x:Name="CategoryBox"
                          Grid.Row="2"
                          Height="42"
                          Margin="0,0,0,14"
                          SelectionChanged="CategoryBox_SelectionChanged"/>

                <ListBox x:Name="ChannelList"
                         Grid.Row="3"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="ChannelList_SelectionChanged"
                         MouseDoubleClick="ChannelList_MouseDoubleClick"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1C2230" CornerRadius="14" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="42" Height="42" CornerRadius="12" Background="#07090D" VerticalAlignment="Center">
                                        <Grid>
                                            <Image Source="{Binding LogoUrl}" Stretch="Uniform" Margin="6"/>
                                            <TextBlock Text="📺" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="#9AA3B5"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid x:Name="PlayerArea" Grid.Column="2" Background="#0B0D12" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="ControlsRow" Height="82"/>
            </Grid.RowDefinitions>

            <Border x:Name="PlayerFrame" Background="Black" Margin="18,18,18,0" CornerRadius="18" ClipToBounds="True">
                <Grid Background="Black">
                    <vlc:VideoView x:Name="VideoPlayer" Background="Black"/>

                    <Border x:Name="OverlayPanel" Background="#CC000000">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="PlayerPlaceholder"
                                       Text="Selecione um canal"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Duplo clique no canal para reproduzir"
                                       Margin="0,12,0,0"
                                       Foreground="#A8B0C0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border x:Name="PlayerControls"
                    Grid.Row="1"
                    Background="#171B25"
                    CornerRadius="16"
                    Margin="18,14,18,18"
                    Padding="14">
                <DockPanel>
                    <Button Content="▶ Reproduzir" Width="130" Margin="0,0,10,0" Background="{StaticResource Accent}" Click="Play_Click"/>
                    <Button Content="⏸ Pausar" Width="100" Margin="0,0,10,0" Click="Pause_Click"/>
                    <Button Content="⛶ Tela cheia" Width="130" DockPanel.Dock="Right" Background="{StaticResource Accent}" Click="Fullscreen_Click"/>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Right" Margin="0,0,14,0">
                        <TextBlock Text="🔊" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="VolumeSlider" Width="120" Minimum="0" Maximum="100" Value="80" ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>

                    <TextBlock x:Name="NowPlayingText"
                               Text="Nenhum canal selecionado"
                               Foreground="White"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
